root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false   # Markdown 里的双空格 = 换行

[*.{yml,yaml}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[*.{json,jsonl}]
indent_size = 2

[*.{ts,tsx,js,jsx}]
indent_size = 2
quote_type = single

[Makefile]
indent_style = tab
