# ============================================================
# pl-pipeline .gitignore
# ============================================================

# ---- OS ----
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- Editors / IDE ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# CodeBuddy / Claude Code / Cursor 的本地缓存与会话（保留 rules/commands/skills 入版本）
.codebuddy/logs/
.codebuddy/cache/
.codebuddy/sessions/
.claude/cache/
.cursor/cache/

# ---- Node / TS ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

dist/
build/
out/
lib/
!cli/lib/
!experiments/cli-nodejs/lib/
*.tsbuildinfo
.turbo/
.next/
.nuxt/
coverage/
.nyc_output/
*.log

# ---- Testing ----
/test-results/
/playwright-report/
/playwright/.cache/

# ---- pl-pipeline runtime outputs ----
# 运行时产物不入版本控制（每个宿主项目自己产出）
pipeline-output/
!pipeline-output/.gitkeep
!pipeline-output/piao/.gitkeep
!pipeline-output/trace/.gitkeep
!pipeline-output/dashboard/.gitkeep

# 本地临时 state（非规范产物）
*.state.local.md
.pl-cache/

# ---- examples/ 里的运行时产物 ----
# examples 里的 demo 项目会被 AI 跑一次 proposal→archive 全流程，
# 保留 pl/ 目录和源码作为证据，但 node_modules / .next / .venv 等不入库
examples/*/node_modules/
examples/*/.next/
examples/*/.nuxt/
examples/*/.venv/
examples/*/__pycache__/
examples/*/*.egg-info/
examples/*/dist/
examples/*/build/
examples/*/.pytest_cache/
examples/*/.mypy_cache/
examples/*/.ruff_cache/

# 以下必须提交（作为 pl-pipeline 真实运行过的证据）
!examples/*/pl/
!examples/*/pl/**
!examples/*/.pl-adapter
!examples/*/.pl-version
!examples/*/package.json
!examples/*/pnpm-lock.yaml
!examples/*/package-lock.json
!examples/*/pyproject.toml
!examples/*/uv.lock
!examples/*/requirements*.txt

# ---- Environment ----
.env
.env.local
.env.*.local
!.env.example

# ---- Misc ----
*.bak
*.tmp
*.orig
.history/

# ---- Skills / Presets local dev override ----
.codebuddy/commands.local/
presets/*/local-test/

# v1.3 dashboard runtime
dashboard/_data.json
dashboard/trace
