{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kuiklypolycity/pl/schemas/taskdag.schema.json",
  "title": "PL TaskDAG",
  "description": "taskdag.md 的结构化字段约束",
  "type": "object",
  "required": ["change_id", "tasks"],
  "properties": {
    "change_id": { "type": "string" },
    "page_id": { "type": "string" },
    "meta": {
      "type": "object",
      "properties": {
        "total_tasks": { "type": "integer", "minimum": 0 },
        "parallel_groups": { "type": "integer", "minimum": 0 },
        "estimate_serial_hours": { "type": "number" },
        "estimate_parallel_hours": { "type": "number" },
        "reuse_ratio": { "type": "string", "description": "如 12/15 = 80%" },
        "blocked_count": { "type": "integer" }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "pattern": "^T[0-9]+$" },
          "name": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string", "pattern": "^T[0-9]+$" }
          },
          "estimate_hours": { "type": "number", "minimum": 0 },
          "kind": { "type": "string", "enum": ["skeleton", "data_model", "data_module", "tracking", "component", "integration", "other"] },
          "output_files": { "type": "array", "items": { "type": "string" } },
          "reuse_components": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "source": { "type": "string" }
              }
            }
          },
          "new_components": { "type": "array", "items": { "type": "string" } },
          "features": { "type": "array", "items": { "type": "string", "pattern": "^F[0-9]+$" } },
          "gates": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string", "enum": ["pending", "in_progress", "blocked", "done"] },
          "blocking_reason": { "type": "string" }
        }
      }
    },
    "integration_gate": {
      "type": "object",
      "properties": {
        "compile": { "type": "array", "items": { "type": "string" } },
        "functional": { "type": "array", "items": { "type": "string" } },
        "selfcheck": { "type": "array", "items": { "type": "string" } },
        "static": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
